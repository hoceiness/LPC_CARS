<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Essential Permissions -->


    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Location Permissions for Tracking -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <uses-permission android:name="android.permission.CAMERA"/>

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ste_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ste_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.LpcOriginApp">

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".AdminHomeActivity" />
        <activity android:name=".SignupActivity" />
        <activity android:name=".EnterVerificationCodeActivity" />
        <activity android:name=".ResetPasswordActivity" />
        <activity android:name=".VerifyResetPasswordActivity" />
        <activity android:name=".MainActivity" />
        <activity android:name=".AddCarActivity" />
        <activity android:name=".CarDetailsActivity" />
        <activity android:name=".ProfileActivity" />
        <activity android:name=".EditProfileActivity" />
        <activity android:name=".BookingDetailsActivity" />
        <activity android:name=".SearchActivity" />
        <activity android:name=".LiveContractsActivity" />
        <activity android:name=".PaymentMethodsActivity" />
        <activity android:name=".PaymentSuccessActivity" />
        <activity android:name=".NotificationsActivity" />
        <activity android:name=".FavouriteActivity" />
        <activity android:name=".TrackingActivity" />
        <activity android:name=".AwaitingReservationActivity" />

        <service
            android:name=".LocationService"
            android:foregroundServiceType="location"
            android:exported="false" />

    </application>

</manifest>
